# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_byte_hex_string
JWT_EXPIRES_IN=7d

# ── AADE myDATA API ───────────────────────────────────────────────────────────
# Register at: https://www.aade.gr/mydata
# Dev / sandbox environment (safe to test against):
MYDATA_BASE_URL=https://mydataapidev.aade.gr/myDATA
# Production (only after AADE approval):
# MYDATA_BASE_URL=https://mydatapi.aade.gr/myDATA

# Your AADE credentials (from developer portal):
MYDATA_USER_ID=              # aade-user-id header value
MYDATA_SUBSCRIPTION_KEY=     # Ocp-Apim-Subscription-Key header value

# ── Mock mode ─────────────────────────────────────────────────────────────────
# Set to "true" to use static mock data instead of calling AADE (no credentials needed)
MYDATA_MOCK=true
# Set to "true" to bypass real Google/Apple/TaxisNet token verification in social auth
SOCIAL_MOCK=true

# ── Google Sign-In ─────────────────────────────────────────────────────────────
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# You need a Web client ID (used by expo-auth-session) + iOS/Android client IDs
GOOGLE_CLIENT_ID=              # Web client ID (for server-side verification)

# ── Apple Sign-In ──────────────────────────────────────────────────────────────
# Configure at: https://developer.apple.com → Identifiers → your App ID → Sign In with Apple
# APPLE_BUNDLE_ID=com.yourcompany.eleftheros   # must match app bundle ID

# ── TaxisNet (GSIS OAuth2) ────────────────────────────────────────────────────
# Register your application at: https://www.aade.gr/
# Sandbox: https://www1.gsis.gr/oauth2server/ (requires AADE approval)
TAXISNET_CLIENT_ID=
TAXISNET_CLIENT_SECRET=
TAXISNET_TOKEN_URL=https://www1.gsis.gr/oauth2server/oauth/token
TAXISNET_INFO_URL=https://www1.gsis.gr/oauth2server/userinfo

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Expo dev client + production domain)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,exp://localhost:8081
